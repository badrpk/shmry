#!/usr/bin/env python3
from flask import Flask, request, jsonify
import sqlite3
import pathlib
import time

from shmry_psx_steel import get_steel_rfq_response as get_rfq_response

app = Flask(__name__)

DB = pathlib.Path.home() / "SHMRY_KERNEL/state/shmry_services.db"

@app.route("/", methods=["GET"])
def index():
    return jsonify({
        "status": "ok",
        "service": "SHMRY Marketplace",
        "version": "v55-steel-bridge-clean"
    })

@app.route("/health", methods=["GET"])
def health():
    return jsonify({
        "status": "healthy",
        "version": "v55-steel-bridge-clean"
    })

@app.route("/api/status", methods=["GET"])
def api_status():
    return jsonify({
        "status": "ok",
        "service": "marketplace",
        "version": "v55-steel-bridge-clean",
        "time": int(time.time())
    })

@app.route("/api/inventory/summary", methods=["GET"])
def inventory_summary():
    try:
        if not DB.exists():
            return jsonify({
                "status": "ok",
                "sku_count": 0,
                "total_value_pkr": 0,
                "note": "inventory db not found"
            })

        con = sqlite3.connect(DB)
        cur = con.cursor()
        cur.execute("SELECT COALESCE(SUM(quantity * price_pkr),0), COUNT(*) FROM inventory")
        value, count = cur.fetchone()
        con.close()

        return jsonify({
            "status": "ok",
            "sku_count": count or 0,
            "total_value_pkr": value or 0
        })
    except Exception as e:
        return jsonify({
            "status": "error",
            "error": str(e)
        }), 500

@app.route("/wa/inbound", methods=["POST"])
@app.route("/wa/inbound/v2", methods=["POST"])
def wa_inbound():
    try:
        data = request.get_json() or {}
        text = data.get("text") or data.get("query") or data.get("message") or ""
        reply_text = get_rfq_response(text)

        return jsonify({
            "status": "ok",
            "reply": reply_text,
            "source": "marketplace_steel_bridge_v55"
        })
    except Exception as e:
        return jsonify({"status": "error", "error": str(e)}), 500

@app.route("/login", methods=["POST"])
def login():
    return jsonify({
        "ok": False,
        "message": "login endpoint placeholder; auth module not enabled"
    }), 501

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000)
