@app.route('/wa/inbound', methods=['POST'])
def wa_inbound():
    from shmry_steel_api import get_rfq_response
    try:
        data = request.get_json() or {}
        text = data.get('text', data.get('message', ''))
        reply = get_rfq_response(text)
        return jsonify({'status': 'ok', 'reply': reply, 'source': 'steel_api'})
    except Exception as e:
        return jsonify({'error': str(e)}), 500
    return jsonify({"status": "ok", "source": "executor", "input": text, "reply": result})

@app.route('/steel/rfq', methods=['POST'])
def steel_rfq():
    data = request.get_json(silent=True) or {}
    return jsonify({"status": "ok", "rfq": data, "message": "Steel RFQ received"})

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000, debug=False)



@app.route('/inventory')
def quick_inventory():
    if not INV_DB.exists():
        return jsonify({"status": "error", "reply": "No inventory DB"}), 404

    con = sqlite3.connect(INV_DB)
    cur = con.cursor()
    cur.execute("SELECT SUM(qty * price_pkr) AS total_value, COUNT(*) AS sku_count FROM inventory")
    row = cur.fetchone()
    con.close()

    return jsonify({
        "status": "ok",
        "sku_count": row[1] or 0,
        "total_value_pkr": row[0] or 0
    })

