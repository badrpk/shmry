# --- SHMRY Steel Bridge v2 ---
from shmry_steel_api import get_rfq_response

@app.route('/wa/inbound/v2', methods=['POST'])
def wa_inbound_v2():
    data = request.get_json() or {}
    text = data.get('text') or data.get('query') or data.get('message') or ''
    reply_text = get_rfq_response(text)
    return jsonify({
        "status": "ok",
        "reply": reply_text,
        "source": "marketplace_steel_bridge_v2"
    })
