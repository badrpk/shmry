#!/usr/bin/env python3
from flask import Flask, jsonify, request
import os, time

app = Flask(__name__)

@app.route("/")
def home():
    return jsonify({
        "message": "SHMRY Marketplace Gateway Running",
        "status": "ok",
        "version": "v34-fixed"
    })

@app.route("/health")
@app.route("/api/health")
def health():
    return jsonify({
        "status": "healthy",
        "service": "shmry_marketplace",
        "version": "v34-fixed",
        "python": os.sys.version.split()[0],
        "time": time.strftime("%Y-%m-%d %H:%M:%S")
    })

@app.route("/test")
def test():
    return jsonify({"status": "ok", "message": "test endpoint working"})

@app.route("/integrations/status")
def integrations_status():
    return jsonify({"status": "ok", "integrations": "available"})

@app.route("/wa/inbound", methods=["POST"])
def wa_inbound():
    data = request.get_json(silent=True) or {}
    text = data.get("text", "")
    return jsonify({
        "status": "received",
        "gateway": "shmry_marketplace",
        "text": text,
        "reply": f"SHMRY received: {text}"
    })

# Quick reasoning integration
from marketplace.shmry_reasoning_core_v34 import app as reasoning_app  # adjust import if needed

@app.route("/ask", methods=["POST"])
@app.route("/ai/chat", methods=["POST"])
def ask_handler():
    from flask import request, jsonify
    data = request.get_json() or request.form or {}
    query = data.get("text") or data.get("Body") or str(data)
    try:
        # Forward to reasoning core if available
        return jsonify({"reply": "SHMRY Reasoning: Margin calculation in progress... (core wired)", "query": query})
    except Exception as e:
        return jsonify({"error": str(e)})
