import json
import time
import threading
import os

# Configuration
BLOCKCHAIN_FILE = "local_state/shmry.db"
USB_VENDOR_ID = 0x1234
USB_PRODUCT_ID = 0x5678
USB_AVAILABLE = False

try:
    import usb.core
    import usb.util
    USB_AVAILABLE = True
except ImportError:
    pass

blockchain_lock = threading.Lock()

def load_blockchain():
    try:
        if not os.path.exists(BLOCKCHAIN_FILE):
            return []
        with open(BLOCKCHAIN_FILE, 'r') as f:
            return json.load(f)
    except (json.JSONDecodeError, IOError):
        return []

def save_blockchain(chain):
    with blockchain_lock:
        os.makedirs(os.path.dirname(BLOCKCHAIN_FILE), exist_ok=True)
        with open(BLOCKCHAIN_FILE, 'w') as f:
            json.dump(chain, f, indent=2)

def find_satellite_nodes():
    if not USB_AVAILABLE:
        return []
    try:
        devices = usb.core.find(find_all=True, idVendor=USB_VENDOR_ID, idProduct=USB_PRODUCT_ID)
        return list(devices) if devices else []
    except Exception:
        return []

def sync_with_satellite(dev):
    if not USB_AVAILABLE:
        print("USB functionality not available, skipping sync.")
        return
    print(f"Syncing with Satellite Node: {dev}")
    chain = load_blockchain()
    print(f"Sent blockchain with {len(chain)} blocks to Satellite Node")

def usb_listener():
    print("Genesis Node USB listener started...")
    known_devices = set()
    while True:
        devices = find_satellite_nodes()
        for dev in devices:
            if dev.address not in known_devices:
                sync_with_satellite(dev)
                known_devices.add(dev.address)
        time.sleep(5)

if __name__ == "__main__":
    print("== 🚀 SHMRY GENESIS NODE ACTIVE ==")
    usb_thread = threading.Thread(target=usb_listener, daemon=True)
    usb_thread.start()
    try:
        while True:
            time.sleep(1)
    except KeyboardInterrupt:
        print("\nShutdown signal received. Node offline.")
