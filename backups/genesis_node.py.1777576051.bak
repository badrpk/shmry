except ImportError:
    print("usb module not found, USB functionality disabled.")
    USB_AVAILABLE = False
# Added TCP server for SHMRY Identity requests from network clients
BLOCKCHAIN_FILE = 'blockchain.json'
USB_VENDOR_ID = 0x1234  # replace with actual vendor id
USB_PRODUCT_ID = 0x5678  # replace with actual product id
blockchain_lock = threading.Lock()
# Load or initialize blockchain ledger
def load_blockchain():
    if os.path.exists(BLOCKCHAIN_FILE):
        with open(BLOCKCHAIN_FILE, 'r') as f:
            return json.load(f)
    else:
        return []
def save_blockchain(chain):
    with blockchain_lock:
        with open(BLOCKCHAIN_FILE, 'w') as f:
            json.dump(chain, f, indent=2)
# Monitor USB devices for Satellite Nodes
# This is a polling approach; can be improved with OS-specific events
def find_satellite_nodes():
    # returns list of USB devices matching vendor and product id
    if not USB_AVAILABLE:
        devices = usb.core.find(find_all=True, idVendor=USB_VENDOR_ID, idProduct=USB_PRODUCT_ID)
    return list(devices) if devices else []
# Handle communication with Satellite Nodes over USB
# For the sake of example, this function will simulate syncing
# A more advanced implementation would use libusb or pyusb bulk transfers
def sync_with_satellite(dev):
        print("USB functionality not available, skipping sync.")
        return
    # placeholder for USB communication logic
    # simulate reading a blockchain update request
        print(f"Syncing with Satellite Node: {dev}")
    chain = load_blockchain()
    # For demo, just re-send full chain
    # Actual USB communication omitted due to complexity
    print(f"Sent blockchain with {len(chain)} blocks to Satellite Node")
def usb_listener():
    print("Genesis Node USB listener started...")
    known_devices = set()
    while True:
        devices = find_satellite_nodes()
        for dev in devices:
            if dev.address not in known_devices:
                known_devices.add(dev.address)
                threading.Thread(target=sync_with_satellite, args=(dev,), daemon=True).start()
        # Poll interval
        import time
        time.sleep(5)
import hashlib
def hash_block(block):
    block_string = json.dumps(block, sort_keys=True).encode('utf-8')
    return hashlib.sha256(block_string).hexdigest()
def handle_client(conn, addr):
    try:
        data = b""
        while True:
            chunk = conn.recv(4096)
            if not chunk:
                break
            data += chunk
            if b'\n' in data or len(data) > 4096:
        if not data:
            return
        try:
            request = json.loads(data.decode('utf-8').strip())
        except Exception:
            conn.sendall(b'{"error":"invalid_json"}\n')
        if request.get('request') == 'shmry_identity':
            # Add the request as a new block in blockchain ledger
            with blockchain_lock:
                chain = load_blockchain()
                block = {
                    'type': 'Identity Request',
                    'request_data': request,
                    'remote_addr': addr[0]
                }
                block_hash = hash_block(block)
                block['hash'] = block_hash
                chain.append(block)
                save_blockchain(chain)
            identity = {
                "node_type": "master",
                "id": "genesis-node-001",
                "status": "active",
                "last_seen": None
            }
            response = json.dumps(identity).encode('utf-8') + b'\n'
            conn.sendall(response)
        else:
            conn.sendall(b'{"error":"unknown_request"}\n')
    finally:
        conn.close()
def tcp_server():
    HOST = '0.0.0.0'
    PORT = 5002
    server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server.bind((HOST, PORT))
    server.listen(5)
    print(f"Genesis Node TCP server listening on {HOST}:{PORT}...")
        conn, addr = server.accept()
        threading.Thread(target=handle_client, args=(conn, addr), daemon=True).start()
