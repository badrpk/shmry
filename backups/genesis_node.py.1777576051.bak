        'devices': devices,
    # Compute SHA-256 hash of block content (string of devices JSON)
    block_string = json.dumps(devices, sort_keys=True).encode('utf-8')
    block['hash'] = hashlib.sha256(block_string).hexdigest()
    blockchain.append(block)
    save_blockchain(blockchain)
    return jsonify({'message': 'Devices synchronized', 'block': block}), 201
