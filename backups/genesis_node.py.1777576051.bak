@flask_app.route('/api/update', methods=['POST'])
def receive_update():
    if not data or 'lid' not in data or 'update' not in data or 'signature' not in data:
        return jsonify({'error': 'Missing update data'}), 400
    lid = data['lid']
    signature = data['signature']
    update = data['update']
    # For demo, check if lid matches authorized LID
    if lid == AUTHORIZED_LID:
        # Append to broadcast tasks so satellites get update
        broadcast_tasks.append(update)
        # Trigger task for satellites to pull latest code (e.g., by sending a special command)
        broadcast_tasks.append({'action': 'pull_latest_code', 'path': os.path.expanduser('~/shmry_core')})
        return jsonify({'message': 'Update accepted and broadcasted'}), 200
