from flask import Flask, request, jsonify
flask_app = Flask(__name__)


from pathlib import Path
def write_auth_block(data):
    import json, datetime
    from pathlib import Path
    bc_dir = Path.home() / ".shmry_blockchain"
    bc_dir.mkdir(exist_ok=True)
    blocks = sorted(bc_dir.glob("block_*.json"))
    idx = len(blocks)
    block = {
        "index": idx,
        "timestamp": datetime.datetime.now().isoformat(),
        "data": data,
        "previous_hash": "AUTO",
        "hash": f"AUTO_{idx}"
    }
    (bc_dir / f"block_{idx}.json").write_text(json.dumps(block, indent=2))
