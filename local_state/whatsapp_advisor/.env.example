# Web
HOST=0.0.0.0
PORT=9010
BASE_URL=https://your-public-url.example.com

# Provider routing (optional)
LLM_PROVIDER=none   # none|openai|gemini
OPENAI_API_KEY=     # if LLM_PROVIDER=openai
GEMINI_API_KEY=     # if LLM_PROVIDER=gemini

# WhatsApp inbound verification (choose one approach)
# (A) Twilio WhatsApp webhook signature validation (optional)
TWILIO_AUTH_TOKEN=
# (B) Meta WhatsApp Cloud API verification (optional)
META_VERIFY_TOKEN=change-me

# Logging
LOG_LEVEL=INFO
